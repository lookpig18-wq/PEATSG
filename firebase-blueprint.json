{
  "entities": {
    "Account": {
      "title": "Account",
      "description": "Budget account information",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "Account code" },
        "name": { "type": "string", "description": "Account name" },
        "budgets": { "type": "object", "description": "Budgets per cost center" }
      },
      "required": ["code", "name", "budgets"]
    },
    "Disbursement": {
      "title": "Disbursement",
      "description": "Disbursement record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "accountCode": { "type": "string" },
        "accountName": { "type": "string" },
        "costCenter": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "tax": { "type": "string" },
        "totalPrice": { "type": "string" },
        "wht": { "type": "string" },
        "netTotal": { "type": "string" },
        "payee": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "attachment": { "type": "string" },
        "attachmentName": { "type": "string" }
      },
      "required": ["id", "date", "description", "price", "payee", "status"]
    },
    "User": {
      "title": "User",
      "description": "User account",
      "type": "object",
      "properties": {
        "password": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["password"]
    }
  },
  "firestore": {
    "accounts/{code}": {
      "schema": "Account",
      "description": "Collection of budget accounts"
    },
    "disbursements/{id}": {
      "schema": "Disbursement",
      "description": "Collection of disbursement records"
    },
    "users/{username}": {
      "schema": "User",
      "description": "Collection of user accounts"
    }
  }
}
