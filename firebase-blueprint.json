{
  "entities": {
    "disbursement": {
      "title": "Disbursement",
      "description": "A record of a budget disbursement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "accountCode": { "type": "string" },
        "accountName": { "type": "string" },
        "costCenter": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "tax": { "type": "string" },
        "totalPrice": { "type": "string" },
        "wht": { "type": "string" },
        "netTotal": { "type": "string" },
        "payee": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "attachment": { "type": "string", "description": "Base64 encoded PDF or URL" },
        "attachmentName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["accountCode", "costCenter", "date", "description", "price", "payee", "status"]
    },
    "account": {
      "title": "Account",
      "description": "Account code and budget allocation",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "budgets": {
          "type": "object",
          "properties": {
            "ผบง.": { "type": "number" },
            "กบห.": { "type": "number" },
            "ผปร.": { "type": "number" },
            "ผบค.": { "type": "number" }
          }
        }
      },
      "required": ["code", "name", "budgets"]
    },
    "user": {
      "title": "User",
      "description": "Application user account",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "guest"] }
      },
      "required": ["username", "password"]
    }
  },
  "firestore": {
    "/disbursements/{disbursementId}": {
      "schema": "disbursement",
      "description": "Collection of disbursement records"
    },
    "/accounts/{accountId}": {
      "schema": "account",
      "description": "Collection of account codes and budgets"
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of user accounts"
    }
  }
}
