rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // For now, we allow anyone authenticated to read/write if they are in the 'users' collection with admin role
      // Or we can use a simple check for the default admin email
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == "Lookpig18@gmail.com"
      );
    }

    // Disbursements
    match /disbursements/{disbursementId} {
      // Allow read/write for everyone because the app uses a custom auth system
      // WARNING: This is insecure for production. Consider using Firebase Auth.
      allow read, write: if true;
    }

    // Accounts
    match /accounts/{accountId} {
      allow read, write: if true;
    }

    // Users
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
